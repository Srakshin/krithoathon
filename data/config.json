{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "en"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "openSIS",
        "repo": "openSIS-Classic",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "LibreSchool",
        "repo": "LibreSchool",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 10,
      "min_score": 200
    },
    "rss": [
      {
        "name": "EdTech News Feed 1",
        "url": "https://example.com/feeds/edtech-news-1.xml",
        "enabled": true,
        "category": "school-management-software"
      },
      {
        "name": "EdTech News Feed 2",
        "url": "https://example.com/feeds/edtech-news-2.xml",
        "enabled": true,
        "category": "teacher-tools"
      },
      {
        "name": "EdTech News Feed 3",
        "url": "https://example.com/feeds/edtech-news-3.xml",
        "enabled": true,
        "category": "edtech-trends"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "Teachers",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "edtech",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24,
    "keywords": [
      "school management software",
      "teacher tools"
    ]
  }
}