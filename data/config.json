{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "api_key_env": "GOOGLE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "en"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "openSIS",
        "repo": "openSIS-Classic",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "LibreSchool",
        "repo": "LibreSchool",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 10,
      "min_score": 200
    },
    "rss": [
      {
        "name": "EdSurge",
        "url": "https://feeds.feedburner.com/EdSurge",
        "enabled": true,
        "category": "edtech-trends"
      },
      {
        "name": "TechCrunch Education",
        "url": "https://techcrunch.com/category/education/feed/",
        "enabled": true,
        "category": "competitors"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "Teachers",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "edtech",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "cietetx",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "edtechreview",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "educationtechnologynews",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "elearningindustry",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "futurepedia_io",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "aipost",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "machinelearningresearchnews",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "googleforeducation",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "openai",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24,
    "keywords": [
      "school management software",
      "teacher tools"
    ]
  }
}
