{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "api_key_env": "GOOGLE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "en"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "instructure",
        "repo": "canvas-lms",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "bigbluebutton",
        "repo": "bigbluebutton",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 50
    },
    "rss": [
      {
        "name": "NYT Education",
        "url": "https://rss.nytimes.com/services/xml/rss/nyt/Education.xml",
        "enabled": true,
        "category": "general"
      },
      {
        "name": "Edutopia",
        "url": "https://www.edutopia.org/feed.xml",
        "enabled": true,
        "category": "teacher tools"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "Teachers",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 25,
          "min_score": 10
        },
        {
          "subreddit": "edtech",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 25,
          "min_score": 10
        }
      ],
      "users": [],
      "fetch_comments": 0
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "cietetx",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "elearningindustry",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "futurepedia_io",
          "enabled": false,
          "fetch_limit": 20
        },
        {
          "channel": "aipost",
          "enabled": false,
          "fetch_limit": 20
        },
        {
          "channel": "machinelearningresearchnews",
          "enabled": false,
          "fetch_limit": 20
        },
        {
          "channel": "googleforeducation",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "openai",
          "enabled": false,
          "fetch_limit": 20
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 72,
    "keywords": [
      "education",
      "school",
      "college",
      "university",
      "student",
      "teacher",
      "learning",
      "course",
      "class",
      "EdTech",
      "LMS",
      "curriculum",
      "teaching",
      "classroom",
      "academic",
      "pedagogy"
    ],
    "minimum_topic_score": 2.0
  },
  "email": {
    "enabled": true,
    "smtp_server": "smtp.gmail.com",
    "smtp_port": 465,
    "email_address": "padidamanveshreddy3@gmail.com",
    "password_env": "EMAIL_PASSWORD",
    "sender_name": "Morning Pulse",
    "imap_server": "imap.gmail.com",
    "imap_port": 993,
    "subscribe_keyword": "Subscribe",
    "unsubscribe_keyword": "Unsubscribe"
